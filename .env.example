# Frontend Environment Variables

# API URL (without trailing slash)
VITE_API_URL=http://localhost:3001/api

# For production, use your backend URL:
# VITE_API_URL=https://api.yourdomain.com/api

# Set to 'true' to use mock data (no backend required)
# Demo accounts: admin@demo.com, clerk@demo.com, collector@demo.com, accountant@demo.com, manager@demo.com
# Any password works in mock mode
VITE_USE_MOCK=false
